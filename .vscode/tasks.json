{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "C/C++: clang++ build active file",
			"command": "/usr/bin/clang++",
			"args": [
				"-fcolor-diagnostics",
				"-fansi-escape-codes",
				"-g",
				"-std=c++23",
				"${file}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"detail": "compiler: /usr/bin/clang++",
		},
		{
			"label": "Run Executable",
			"type": "shell",
			"command": "\"${fileDirname}/a.out\"",
			"problemMatcher": [],
			"dependsOn": [
				"C/C++: clang++ build active file"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}
